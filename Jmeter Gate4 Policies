#!/usr/bin/env bash
set -euo pipefail

echo "🚦 Gate-4: Performance & Runtime Security Policy"

FAIL=0

# -------------------------------
# 1️⃣ Performance SLA Check
# -------------------------------
echo "⏱️ Checking Performance SLA..."

AVG_RESPONSE=$(jq -r '.aggregate.average.responseTime' perf-report.json)
SLA_THRESHOLD=2000

if awk "BEGIN {exit !($AVG_RESPONSE <= $SLA_THRESHOLD)}"; then
  echo "✅ SLA OK: $AVG_RESPONSE ms"
else
  echo "❌ SLA Violated: $AVG_RESPONSE ms (Threshold: $SLA_THRESHOLD ms)"
  FAIL=1
fi


# -------------------------------
# 2️⃣ Error Rate Check
# -------------------------------
echo "📉 Checking Error Rate..."

ERROR_RATE=$(jq -r '.aggregate.errorRate' perf-report.json)
ERROR_THRESHOLD=1

if awk "BEGIN {exit !($ERROR_RATE < $ERROR_THRESHOLD)}"; then
  echo "✅ Error Rate OK: $ERROR_RATE%"
else
  echo "❌ High Error Rate: $ERROR_RATE% (Threshold: < $ERROR_THRESHOLD%)"
  FAIL=1
fi


# -------------------------------
# 3️⃣ Lockout Mechanism Check
# -------------------------------
echo "🔐 Checking Lockout Policy..."

LOCK_STATUS=$(jq -r '.lockoutTriggered' auth-report.json)

if [ "$LOCK_STATUS" = "true" ]; then
  echo "✅ Lockout mechanism working"
else
  echo "❌ Weak Lockout Mechanism detected"
  FAIL=1
fi


# -------------------------------
# 4️⃣ Concurrent Login Check
# -------------------------------
echo "👥 Checking Concurrent Login Policy..."

MAX_ALLOWED=1
ACTIVE_SESSIONS=$(jq -r '.activeSessions' auth-report.json)

if [ "$ACTIVE_SESSIONS" -le "$MAX_ALLOWED" ]; then
  echo "✅ Concurrent session policy enforced"
else
  echo "❌ Multiple active sessions detected ($ACTIVE_SESSIONS)"
  FAIL=1
fi


# -------------------------------
# Final Decision
# -------------------------------
if [ "$FAIL" -eq 0 ]; then
  echo "🎉 Gate-4 PASSED: Application meets Performance & Security policies"
  exit 0
else
  echo "🚫 Gate-4 FAILED: Policy violations detected"
  exit 1
fi
