#!/usr/bin/env bash
set -euo pipefail

echo "⏱️ Gate-4: Performance SLA Check"

AVG_RESPONSE=$(jq '.aggregate.average.responseTime' perf-report.json)

THRESHOLD=2000

if awk "BEGIN {exit !($AVG_RESPONSE <= $THRESHOLD)}"; then
  echo "✅ Response time within SLA ($AVG_RESPONSE ms)"
else
  echo "❌ SLA Violated! Average response time: $AVG_RESPONSE ms"
  exit 1
fi
✔ Fails if response time > 2000 ms
